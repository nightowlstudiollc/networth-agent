# .claude/secrets.op.template — 1Password secret references template
# Copy to .claude/secrets.op (gitignored) and update paths for your vault.
#
# Format: KEY=op://vault-name/item-name/field-name
# Run `op vault list` to see your vault names.
# Run `op item list` to see your item names.
# Run `op item get ITEM_NAME --fields label` to see field names.

# Coinbase Advanced Trade API
COINBASE_API_KEY=op://Personal/Coinbase/YOUR_FIELD_NAME
COINBASE_API_SECRET=op://Personal/Coinbase/YOUR_PRIVATE_KEY_FIELD

# Mercury Banking API
MERCURY_API_TOKEN=op://Personal/Mercury/YOUR_TOKEN_FIELD

# Plaid API
PLAID_CLIENT_ID=op://Personal/Plaid/YOUR_CLIENT_ID_FIELD
PLAID_SECRET=op://Personal/Plaid/YOUR_PRODUCTION_SECRET_FIELD
PLAID_SANDBOX_SECRET=op://Personal/Plaid/YOUR_SANDBOX_SECRET_FIELD
